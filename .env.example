# Contact form email delivery via Resend (https://resend.com)
# All variables below are SERVER-ONLY (never exposed to the browser).
# Without RESEND_API_KEY the contact form falls back to opening the
# visitor's own mail client (status: "unconfigured") — the site still works.

# Optional in dev / recommended in prod: Resend API key. Server-only.
RESEND_API_KEY=re_your_api_key_here

# Optional: verified "from" name/address used when sending.
# Must be verified in your Resend account / domain.
# Defaults to "FlegarTech Website <onboarding@resend.dev>" if unset.
CONTACT_FROM_EMAIL=FlegarTech Website <noreply@yourdomain.com>

# Optional: address that receives contact form submissions.
# Defaults to siteConfig.email if unset.
CONTACT_TO_EMAIL=hello@yourdomain.com
